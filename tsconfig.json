{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@app/*": [
        "./app/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "drizzle/**/*",
    "*.ts",
    "*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
